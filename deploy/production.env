apiVersion: deployment.jorisjonkers.dev/env/v1
kind: DeploymentEnvironment
metadata:
  name: production
spec:
  values:
    DEPLOYMENT_ENVIRONMENT: production
    OTEL_SERVICE_NAME: agents-api
    OTEL_EXPORTER_OTLP_ENDPOINT: http://alloy.observability.svc.cluster.local:4318
    OTEL_EXPORTER_OTLP_PROTOCOL: http/protobuf
    OTEL_LOGS_EXPORTER: none
    OTEL_METRICS_EXPORTER: none
    OTEL_TRACES_EXPORTER: otlp
    PYROSCOPE_APPLICATION_NAME: agents-api
    PYROSCOPE_SERVER_ADDRESS: http://pyroscope.observability.svc.cluster.local:4040
    PYROSCOPE_FORMAT: jfr
  overrides:
    agents-api:
      replicas: 1
    agents-api-ws:
      replicas: 1
