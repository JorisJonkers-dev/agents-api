apiVersion: deployment.jorisjonkers.dev/env/v1
kind: DeploymentEnvironment
metadata:
  name: runtime
spec:
  values:
    SERVER_PORT: '8082'
    SPRING_PROFILES_ACTIVE: prod
    SPRING_CONFIG_IMPORT: vault://
    VAULT_ENABLED: 'true'
    VAULT_DB_ENABLED: 'true'
    DB_HOST: postgres.data-system.svc.cluster.local
    DB_PORT: '5432'
    VALKEY_HOST: valkey.data-system.svc.cluster.local
    VALKEY_PORT: '6379'
    SPRING_RABBITMQ_HOST: rabbitmq.data-system.svc.cluster.local
    SPRING_RABBITMQ_PORT: '5672'
    AGENT_RUNTIME_NAMESPACE: agents-system
    AGENT_RUNTIME_NODE: enschede-gtx-960m-1
    AGENT_RUNTIME_DOCKER_SOCKET_SUPPLEMENTAL_GROUPS: '131'
    CREDENTIAL_WORKER_URL: http://agents-login-worker.agents-system.svc.cluster.local:8081
